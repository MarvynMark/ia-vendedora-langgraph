# Server
PORT=3000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vestigium
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vestigium

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2
OPENAI_MODEL_MINI=gpt-4.1-mini

# Chatwoot
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=your-api-token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_ALERT_INBOX_ID=1
CHATWOOT_ALERT_CONVERSATION_ID=1

# ElevenLabs
ELEVENLABS_API_KEY=xi-...
# Valor default: Keren
ELEVENLABS_VOICE_ID=33B4UnXyTNbgLmdEDh5P

# Timezone
TZ=America/Sao_Paulo

# Langfuse (observability – opcional)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASEURL=https://cloud.langfuse.com

# Timing
DEBOUNCE_DELAY_MS=16000
LOCK_MAX_RETRIES=5
LOCK_RETRY_DELAY_MS=3000

# Grupo de espera (link do WhatsApp)
GRUPO_ESPERA_LINK=https://chat.whatsapp.com/BFRcUIZD4tp85KfF1rNCHU

# Delay para envio do template se lead não entrar em contato (em ms, padrão 5 min)
TEMPLATE_DELAY_MS=300000
